# ─────────────────────────────────────────────────────────────────────────────
# Aaroksha Health Hub — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# ⚠️  NEVER commit `.env` to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe for frontend, enforced by RLS)
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon/public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Super Admin email — used ONLY for the password-reset whitelist check.
# Must exactly match the email registered in Supabase Auth.
VITE_SUPER_ADMIN_EMAIL=your-admin-email@example.com
