# ─────────────────────────────────────────────────────────────────────────────
# Aaroksha Health Hub — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# ⚠️  NEVER commit `.env` to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe for frontend, enforced by RLS)
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon/public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Production Site URL (used for Auth redirects)
# Set this to https://www.aaroksha.in in production
VITE_SITE_URL=https://www.aaroksha.in

# NOTE: No other secrets belong here.
# The Super Admin email whitelist is managed server-side in the
# `admin_whitelist` table in Supabase (protected by Row Level Security).
# Never put admin emails or passwords in frontend environment variables.
